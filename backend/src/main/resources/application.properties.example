# Configuración de Base de Datos MySQL
spring.datasource.url=jdbc:mysql://localhost:3307/nomina_asistencia?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=TU_PASSWORD_AQUI

# Hibernate / JPA
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=true

# Servidor
server.port=8080

# JWT (RS256). Si no existen archivos locales, el servidor puede generar una clave efímera.
jwt.issuer=chiokore-nomina-idp
jwt.rsa.key-id=chiokore-nomina-v1
jwt.rsa.private-key-path=src/main/resources/keys/private_key.pem
jwt.rsa.public-key-path=src/main/resources/keys/public_key.pem
jwt.access-expiration=86400

# Data seeding via DataInitializer (CommandLineRunner)
