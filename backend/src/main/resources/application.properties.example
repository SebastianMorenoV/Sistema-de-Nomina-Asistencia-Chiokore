# Configuración de Base de Datos MySQL
spring.datasource.url=jdbc:mysql://localhost:3307/nomina_asistencia?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=TU_PASSWORD_AQUI

# Hibernate / JPA
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=true

# Servidor
server.port=9000

# JWT (jjwt + HMAC-SHA256). Genera un secreto: openssl rand -base64 32
jwt.secret=GENERA_TU_PROPIO_SECRETO_BASE64_AQUI
jwt.access-expiration=86400

# Data seeding via DataInitializer (CommandLineRunner)
